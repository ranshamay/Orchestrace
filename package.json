{
  "name": "orchestrace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo run test",
    "lint": "eslint .",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\"",
    "clean": "turbo clean && rm -rf node_modules",
    "start": "zsh -lc \"(lsof -ti:4310 -ti:3000 | xargs kill -9 >/dev/null 2>&1 || true); concurrently -n 'backend,frontend' -c 'blue,green' 'pnpm --filter @orchestrace/cli dev ui --port 4310' 'pnpm --filter @orchestrace/ui dev'\""
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
