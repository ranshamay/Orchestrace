# LLM Provider API Keys (pi-ai reads these automatically)
# Set the keys for providers you want to use.
# See: https://www.npmjs.com/package/@mariozechner/pi-ai#environment-variables

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Default provider/model (used when task doesn't specify one)
ORCHESTRACE_DEFAULT_PROVIDER=anthropic
ORCHESTRACE_DEFAULT_MODEL=claude-sonnet-4-20250514

# Sandbox
ORCHESTRACE_MAX_PARALLEL=4
ORCHESTRACE_WORKTREE_DIR=.worktrees
