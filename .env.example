# Preferred authentication: use persistent auth storage.
#   pnpm --filter @orchestrace/cli dev auth
# This stores credentials in auth.json (OAuth or API keys).

# Optional fallback: environment variables (not required)
# See: https://www.npmjs.com/package/@mariozechner/pi-ai#environment-variables
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# XAI_API_KEY=
# OPENROUTER_API_KEY=
# COPILOT_GITHUB_TOKEN=
# GH_TOKEN=
# GITHUB_TOKEN=

# Persisted auth file used by `orchestrace auth`
# ORCHESTRACE_AUTH_FILE=auth.json

# Default provider/model (used when task doesn't specify one)
ORCHESTRACE_DEFAULT_PROVIDER=anthropic
ORCHESTRACE_DEFAULT_MODEL=claude-sonnet-4-20250514

# Sandbox
ORCHESTRACE_MAX_PARALLEL=4
ORCHESTRACE_WORKTREE_DIR=.worktrees
